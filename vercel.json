{
  "rewrites": [
    { "source": "/", "destination": "/GlucoBro.html" }
  ],
  "functions": {
    "api/libre.js": {
      "memory": 128,
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
