{
  "rewrites": [
    { "source": "/", "destination": "/GlucoBro.html" }
  ],
  "crons": [
    { "path": "/api/cron", "schedule": "*/5 * * * *" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
